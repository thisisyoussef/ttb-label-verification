# Run `npm run env:bootstrap` to create an ignored local `.env` from the gauntlet env inventory.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_VISION_DETAIL=auto
OPENAI_SERVICE_TIER=
OPENAI_STORE=false
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=5000
GEMINI_MEDIA_RESOLUTION=
GEMINI_SERVICE_TIER=
GEMINI_THINKING_BUDGET=
PORT=8787

# Optional trace-driven development for AI and agentic stories only.
# Keep tracing off by default and only enable it for approved local dev or eval fixtures.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ttb-label-verification-dev
LANGSMITH_TRACING=false

# Optional Stitch automation for local workflow tooling only
STITCH_FLOW_MODE=automated
STITCH_API_KEY=
STITCH_PROJECT_ID=3197911668966401642
STITCH_PROJECT_TITLE=TTB Label Verification System
STITCH_MODEL_ID=GEMINI_3_1_PRO
STITCH_DEVICE_TYPE=DESKTOP
STITCH_AUTOMATION_REVIEW_REQUIRED=true
STITCH_GENERATION_TIMEOUT_MS=180000
STITCH_DOWNLOAD_TIMEOUT_MS=60000

# Enable the /eval stakeholder demo page in the client (dev-only).
# Unset or "0" hides the route and the main app renders instead.
VITE_ENABLE_EVAL_DEMO=1

# Developer toolbench (scenario picker, batch seeds, provider override).
# Always visible in dev. In production builds, set to 'true' to keep it
# available for demos; leave unset to hide it for the grandma-test UX.
VITE_ENABLE_TOOLBENCH=
