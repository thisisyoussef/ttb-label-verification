# Run `npm run env:bootstrap` to create an ignored local `.env` from the gauntlet env inventory.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_VISION_DETAIL=auto
OPENAI_SERVICE_TIER=
OPENAI_STORE=false
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=5000
GEMINI_MEDIA_RESOLUTION=
GEMINI_SERVICE_TIER=
GEMINI_THINKING_BUDGET=
PORT=8787

# Optional trace-driven development for AI and agentic stories only.
# Keep tracing off by default and only enable it for approved local dev or eval fixtures.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ttb-label-verification-dev
LANGSMITH_TRACING=false

# Optional Stitch automation for local workflow tooling only
STITCH_FLOW_MODE=automated
STITCH_API_KEY=
STITCH_PROJECT_ID=3197911668966401642
STITCH_PROJECT_TITLE=TTB Label Verification System
STITCH_MODEL_ID=GEMINI_3_1_PRO
STITCH_DEVICE_TYPE=DESKTOP
STITCH_AUTOMATION_REVIEW_REQUIRED=true
STITCH_GENERATION_TIMEOUT_MS=180000
STITCH_DOWNLOAD_TIMEOUT_MS=60000

# Enable the /eval stakeholder demo page in the client (dev-only).
# Unset or "0" hides the route and the main app renders instead.
VITE_ENABLE_EVAL_DEMO=1

# Developer toolbench (COLA Cloud sample loader, provider override).
# Visible by default so assessors can one-click load a real COLA
# sample. Set to 'false' to hide in a customer-facing demo.
VITE_ENABLE_TOOLBENCH=

# Optional demo narration provider for scripts/record-assistant-demo.ts
# If ELEVENLABS_API_KEY is present, demo recording will use ElevenLabs TTS
# unless DEMO_TTS_PROVIDER overrides it back to 'system'.
DEMO_TTS_PROVIDER=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.2
ELEVENLABS_SPEED=0.92
ELEVENLABS_USE_SPEAKER_BOOST=true

# --- Production latency + accuracy tuning (all optional; defaults ship
# in code) ---

# AI provider routing. 'cloud' uses Gemini+OpenAI (default on Railway).
# 'local' routes everything through a local Ollama endpoint. The
# architecture is model-agnostic: same ReviewExtractor interface, same
# downstream deterministic pipeline, swappable via this single switch.
AI_PROVIDER=cloud
AI_EXTRACTION_MODE_DEFAULT=cloud
AI_EXTRACTION_MODE_ALLOW_LOCAL=false

# LLM uncertainty resolver — one-directional review→pass upgrader.
# Production Railway envs enable this for the extra ~3 auto-approvals
# per 28-label run we measured.
LLM_RESOLVER=enabled
LLM_RESOLVER_THRESHOLD=0.60

# Legacy full-field LLM judgment layer. Kept for A/B; regressed on our
# corpus so it's 'disabled' in production.
LLM_JUDGMENT=disabled

# Optional per-field region detection. Regressed on our corpus, opt-in.
REGION_DETECTION=disabled

# Batch pipelining concurrency. Default 5 (sweet spot vs Gemini
# Flash-Lite rate limits; 4.7× speedup on 28-label corpus). Clamped 1-8.
BATCH_CONCURRENCY=5

# Cross-label resolver aggregation in batch mode. Off by default; at
# BATCH_CONCURRENCY=5 the per-label calls already parallelize. Turn
# on if you're close to the provider's rate-limit ceiling.
BATCH_RESOLVER_AGGREGATION=disabled

# Verification-mode extraction for identifier fields (brand, fanciful,
# class, country, address). When on, the VLM prompt includes the
# applicant-declared values and asks "is this visible on the label?"
# rather than bottom-up-extracting each. Numeric fields (ABV, net
# contents, warning) stay bottom-up. Off by default — flip to 'on'
# to A/B against the current eval baseline. See
# docs/specs/verification-mode-extraction.md.
VERIFICATION_MODE=off

# Opt-in experimental paths (all default to off unless listed above):
# GEMINI_STREAM=enabled            — wire-level streaming VLM response
# GEMINI_PRESCALE_EDGE=1024        — pre-downscale image to 1024px
# EXTRACTION_FEW_SHOT=enabled      — 3-shot prompt appendix
# EXTRACTION_PIPELINE=simple       — skip OCR reconciler
# EXTRACTION_TRUSTED_TIER=minimal  — revert to pre-expanded VLM trust set

# --- Local track (AI_PROVIDER=local) only ---
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_VISION_MODEL=qwen2.5vl:3b
# OLLAMA_JUDGMENT_MODEL=llama3.1:8b
# LLM_JUDGMENT_PROVIDER=ollama     — explicit override of judgment provider
