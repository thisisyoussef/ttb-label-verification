{
  "name": "ttb-label-verification",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm run hooks:install",
    "dev": "concurrently -k -n WEB,API -c cyan,yellow \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite --host 0.0.0.0 --port 5176",
    "dev:api": "tsx watch src/server/index.ts",
    "env:bootstrap": "tsx scripts/dev/bootstrap-local-env.ts",
    "hooks:install": "tsx scripts/git-hooks/install-git-hooks.ts",
    "evals:validate": "tsx scripts/evals/validate-evals.ts",
    "eval:llm": "vitest run --config ls.vitest.config.ts",
    "eval:golden": "npm run evals:validate && npm run eval:llm",
    "eval:golden:batch": "tsx scripts/evals/run-gemini-batch-extraction-benchmark.ts",
    "eval:golden:full": "npm run eval:golden && npm run eval:golden:batch",
    "build": "vite build && tsup src/server/index.ts --format esm --target node20 --out-dir dist/server --clean",
    "preview": "vite preview --host 0.0.0.0 --port 4176",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "guard:source-size": "tsx scripts/git-hooks/check-source-size.ts",
    "story:branch": "tsx scripts/git-hooks/story-branch.ts",
    "gate:commit-msg": "tsx scripts/git-hooks/git-commit-msg-gate.ts",
    "gate:commit": "tsx scripts/git-hooks/git-story-gate.ts commit",
    "gate:push": "tsx scripts/git-hooks/git-story-gate.ts push",
    "gate:publish": "tsx scripts/git-hooks/git-story-gate.ts publish",
    "langsmith:smoke": "tsx scripts/dev/langsmith-smoke-test.ts",
    "stitch:smoke": "tsx scripts/stitch/stitch-smoke-test.ts",
    "stitch:mcp-proxy": "tsx scripts/stitch/stitch-mcp-proxy.ts",
    "stitch:story": "tsx scripts/stitch/stitch-story.ts",
    "generate:label-assets": "tsx scripts/fixtures/generate-live-label-assets.ts",
    "model:cache": "tsx scripts/dev/cache-local-model.ts"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "@google/stitch-sdk": "^0.1.0",
    "@huggingface/transformers": "^4.0.1",
    "@types/multer": "^2.1.0",
    "express": "^4.21.2",
    "langsmith": "^0.5.18",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pdf-to-img": "^4.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "fast-check": "^4.6.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
