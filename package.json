{
  "name": "ttb-label-verification",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c cyan,yellow \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite --host 0.0.0.0 --port 5176",
    "dev:api": "tsx watch src/server/index.ts",
    "build": "vite build && tsup src/server/index.ts --format esm --target node20 --out-dir dist/server --clean",
    "preview": "vite preview --host 0.0.0.0 --port 4176",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "openai": "^6.33.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
